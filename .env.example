# Copy to .env and fill in values

# Secret for signing session tokens — change this to something random!
SECRET=change-me-to-something-random-and-long

# Protects the home page (create episode). Guests don't need this — they
# use the room URL + room password directly. Leave blank to disable.
SITE_PASSWORD=

# Port to listen on (production)
PORT=3000
# Dev WebSocket server port (npm run dev). Must match in vite proxy; change if 3001 is busy.
DEV_WS_PORT=3001
HTTPS=false #(true if on web)
# Path to SQLite database file
DB_PATH=./data/rooms.db

# Optional: guest upload handoff to n8n/Google Drive flow
# Webhook endpoint used by server-side native guest upload.
N8N_WEBHOOK_URL=
# Basic Auth — must match the Webhook node’s Basic Auth in n8n (same workflow as this URL).
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASS=
# Max WAV upload size in MB (1 hour mono 48kHz/16-bit ~= 345.6 MB)
MAX_UPLOAD_MB=400
