{
  "name": "podcast-recorder",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"vite dev\" \"node --env-file=.env server-ws-dev.js\"",
    "build": "vite build",
    "start": "node --env-file=.env server.js",
    "preview": "vite preview",
    "rooms": "node scripts/rooms.js list",
    "rooms:delete": "node scripts/rooms.js delete",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@sveltejs/kit": "^2.56.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.2.0",
    "svelte": "^5.39.2",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.0.1",
    "concurrently": "^9.2.1",
    "vite": "^8.0.5",
    "vitest": "^2.0.0",
    "@vitest/ui": "^2.0.0"
  }
}